    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug backend (serve)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=backend",
                    "--package=backend",
                    "--manifest-path=${workspaceFolder}/src/backend/Cargo.toml"
                ],
                "filter": {
                    "name": "backend",
                    "kind": "bin"
                }
            },
            "args": ["serve"],
            "cwd": "${workspaceFolder}/src/backend"
        },
        {
            "name": "Debug backend (seed)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=backend",
                    "--package=backend",
                    "--manifest-path=${workspaceFolder}/src/backend/Cargo.toml"
                ],
                "filter": {
                    "name": "backend",
                    "kind": "bin"
                }
            },
            "args": ["seed"],
            "cwd": "${workspaceFolder}/src/backend"
        }
    ]
}
